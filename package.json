{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "yarn services:up && yarn wait-for-postgres && yarn migration:up && next dev",
    "test": "yarn services:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "test:ci": "yarn services:upci && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "services:up": "wsl docker compose -f infra/compose.yaml up -d",
    "services:upci": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "wsl docker compose -f infra/compose.yaml stop",
    "services:down": "wsl docker compose -f infra/compose.yaml down",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "next lint --dir .",
    "test:watch": "jest --watchAll --runInBand",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js",
    "prepare": "husky"
  },
  "repository": "https://github.com/okborges/clone-tabnews.git",
  "author": "Rafael Borges <rafael.okborges@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "16.4.4",
    "dotenv-expand": "11.0.6",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.4",
    "next": "13.1.6",
    "node-pg-migrate": "6.2.2",
    "pg": "8.11.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "concurrently": "8.2.2",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.6.0",
    "husky": "9.1.4",
    "jest": "29.6.2",
    "prettier": "^2.8.8"
  }
}
